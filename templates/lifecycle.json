{
  "version": "1.0",
  "description": "8-phase project lifecycle for /start-project meta-command",
  "phases": [
    {
      "id": "discovery",
      "order": 1,
      "name": "Discovery",
      "tagline": "Ne yapıyoruz ve neden?",
      "entry_criteria": "Project type identified",
      "exit_criteria": "PRD and user stories written",
      "preferred_agents": ["business-analyst", "market-researcher", "ux-researcher", "product-manager"],
      "preferred_skills": ["brainstorming", "jobs-to-be-done", "user-personas", "market-research"],
      "outputs": ["docs/PRD.md", "docs/user-stories.md", "docs/personas.md"],
      "typical_duration": "1-3 sessions",
      "questions_to_user": [
        "Bu proje hangi problemi çözüyor?",
        "Hedef kullanıcı kim?",
        "Başarı nasıl ölçülecek?",
        "Rakipler/alternatifler neler?"
      ]
    },
    {
      "id": "planning",
      "order": 2,
      "name": "Planning",
      "tagline": "Nasıl yapacağız?",
      "entry_criteria": "Discovery phase complete",
      "exit_criteria": "Technical plan, milestones, risk register",
      "preferred_agents": ["planner", "architect", "product-manager", "cs-project-manager"],
      "preferred_skills": ["project-planning", "risk-analysis", "roadmap", "milestone-tracking"],
      "outputs": ["docs/PLAN.md", "docs/ROADMAP.md", "docs/risks.md"],
      "typical_duration": "1-2 sessions",
      "questions_to_user": [
        "Hangi teknoloji stack'ini kullanacağız?",
        "Zaman çizelgesi ne olacak?",
        "Ekip boyutu nedir?",
        "Kritik bağımlılıklar neler?"
      ]
    },
    {
      "id": "design",
      "order": 3,
      "name": "Design",
      "tagline": "Neye benzeyecek?",
      "entry_criteria": "Planning phase complete",
      "exit_criteria": "Wireframes, API spec, DB schema",
      "preferred_agents": ["ui-designer", "api-designer", "database-architect", "architect"],
      "preferred_skills": ["design-system", "api-design", "schema-design", "c4-architecture"],
      "outputs": ["docs/architecture.md", "docs/api-spec.md", "docs/db-schema.md"],
      "typical_duration": "2-3 sessions",
      "questions_to_user": [
        "Kullanıcı akışları nasıl olacak?",
        "Hangi API endpoint'leri gerekli?",
        "Veri modeli nasıl şekillenecek?"
      ]
    },
    {
      "id": "build",
      "order": 4,
      "name": "Build",
      "tagline": "Kod yazma",
      "entry_criteria": "Design phase complete, tasks broken down",
      "exit_criteria": "Features implemented and working",
      "preferred_agents": ["fullstack-developer", "frontend-developer", "backend-developer", "tdd-guide"],
      "preferred_skills": ["tdd", "coding-standards", "clean-code", "refactor"],
      "outputs": ["src/**", "tests/**"],
      "typical_duration": "Multiple sessions",
      "questions_to_user": [
        "Hangi özellikten başlayalım?",
        "TDD mi direkt implementation mı?"
      ]
    },
    {
      "id": "test",
      "order": 5,
      "name": "Test",
      "tagline": "Doğru mu çalışıyor?",
      "entry_criteria": "Build phase complete or feature-ready",
      "exit_criteria": "Test suite passing, coverage >= 80%",
      "preferred_agents": ["test-automator", "qa-expert", "e2e-runner", "tdd-guide"],
      "preferred_skills": ["unit-testing", "e2e-testing", "test-coverage", "mutation-testing"],
      "outputs": ["tests/**", "docs/test-report.md"],
      "typical_duration": "1-2 sessions per feature"
    },
    {
      "id": "document",
      "order": 6,
      "name": "Document",
      "tagline": "Nasıl kullanılır?",
      "entry_criteria": "Features tested",
      "exit_criteria": "README, API docs, user guides written",
      "preferred_agents": ["technical-writer", "api-documenter", "doc-updater"],
      "preferred_skills": ["readme", "api-documentation", "tutorials", "changelog"],
      "outputs": ["README.md", "docs/api.md", "docs/guide.md", "CHANGELOG.md"]
    },
    {
      "id": "ship",
      "order": 7,
      "name": "Ship",
      "tagline": "Canlıya nasıl çıkar?",
      "entry_criteria": "Docs complete",
      "exit_criteria": "Production deployment active, monitoring in place",
      "preferred_agents": ["deployment-engineer", "devops-engineer", "sre-engineer", "docker-expert"],
      "preferred_skills": ["docker", "ci-cd", "deployment-patterns", "kubernetes"],
      "outputs": [".github/workflows/**", "Dockerfile", "docs/deployment.md"]
    },
    {
      "id": "maintain",
      "order": 8,
      "name": "Maintain",
      "tagline": "Nasıl sağlıklı kalır?",
      "entry_criteria": "Production deployed",
      "exit_criteria": "Ongoing monitoring, dep updates, bug fixes",
      "preferred_agents": ["performance-engineer", "security-engineer", "refactor-cleaner", "database-optimizer"],
      "preferred_skills": ["monitoring", "performance-profiling", "dep-audit", "security-audit"],
      "outputs": ["docs/runbook.md", "docs/post-mortems/**"]
    }
  ],
  "handoffs": [
    {"from": "discovery", "to": "planning", "payload": "PRD + user stories + personas"},
    {"from": "planning", "to": "design", "payload": "Plan + tech stack + risks"},
    {"from": "design", "to": "build", "payload": "Architecture + API spec + DB schema"},
    {"from": "build", "to": "test", "payload": "Feature-complete code"},
    {"from": "test", "to": "document", "payload": "Passing test suite + coverage report"},
    {"from": "document", "to": "ship", "payload": "Docs + deployment checklist"},
    {"from": "ship", "to": "maintain", "payload": "Production URLs + monitoring dashboards"}
  ]
}
