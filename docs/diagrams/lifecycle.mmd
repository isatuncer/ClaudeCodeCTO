%% Lifecycle Orchestration — /start-project meta-command akışı
%% Claude kullanıcıyı proje baştan sona yönlendirir

flowchart TB
    START([/start-project]) --> ASK[Proje türü sor<br/>web/mobile/cli/lib/saas]
    ASK --> LOAD[lifecycle.json yükle<br/>state.json başlat]

    LOAD --> P1

    subgraph P1["📍 Phase 1: DISCOVERY"]
        direction TB
        P1A[business-analyst agent] --> P1B[market-researcher agent]
        P1B --> P1C[ux-researcher agent]
        P1C --> P1D[PRD yaz<br/>user stories]
    end

    P1 --> GATE1{Phase 1<br/>tamam mı?}
    GATE1 -->|Hayır| P1
    GATE1 -->|Evet| SAVE1[state.json güncelle<br/>Phase 1 ✅]

    SAVE1 --> P2

    subgraph P2["📋 Phase 2: PLANNING"]
        direction TB
        P2A[planner agent] --> P2B[architect agent]
        P2B --> P2C[product-manager agent]
        P2C --> P2D[Plan + roadmap<br/>risk analizi]
    end

    P2 --> GATE2{Phase 2<br/>tamam mı?}
    GATE2 -->|Hayır| P2
    GATE2 -->|Evet| SAVE2[Phase 2 ✅]

    SAVE2 --> P3

    subgraph P3["🎨 Phase 3: DESIGN"]
        direction TB
        P3A[ui-designer] --> P3B[api-designer]
        P3B --> P3C[database-architect]
        P3C --> P3D[Wireframe + API spec<br/>DB schema]
    end

    P3 --> SAVE3[Phase 3 ✅]
    SAVE3 --> P4

    subgraph P4["💻 Phase 4: BUILD"]
        direction TB
        P4A[planner → tasklar] --> P4B[tdd-guide<br/>test önce]
        P4B --> P4C[frontend/backend/<br/>fullstack-developer]
        P4C --> P4D[code-reviewer]
    end

    P4 --> SAVE4[Phase 4 ✅]
    SAVE4 --> P5

    subgraph P5["🧪 Phase 5: TEST"]
        direction TB
        P5A[test-automator] --> P5B[qa-expert]
        P5B --> P5C[e2e-runner]
        P5C --> P5D[Coverage raporu<br/>smoke test]
    end

    P5 --> SAVE5[Phase 5 ✅]
    SAVE5 --> P6

    subgraph P6["📚 Phase 6: DOCUMENT"]
        direction TB
        P6A[technical-writer] --> P6B[api-documenter]
        P6B --> P6C[doc-updater]
        P6C --> P6D[README + API docs<br/>tutorials]
    end

    P6 --> SAVE6[Phase 6 ✅]
    SAVE6 --> P7

    subgraph P7["🚀 Phase 7: SHIP"]
        direction TB
        P7A[deployment-engineer] --> P7B[devops-engineer]
        P7B --> P7C[sre-engineer]
        P7C --> P7D[Production deploy<br/>monitoring aktif]
    end

    P7 --> SAVE7[Phase 7 ✅]
    SAVE7 --> P8

    subgraph P8["🔧 Phase 8: MAINTAIN"]
        direction TB
        P8A[performance-engineer] --> P8B[security-engineer]
        P8B --> P8C[refactor-cleaner]
        P8C --> P8D[Sürekli izleme<br/>bakım döngüsü]
    end

    P8 --> DONE([✅ Proje tamamlandı])

    subgraph STATE["💾 Sürekli state tracking"]
        direction LR
        STATE1[project-state.json]
        STATE2[Hangi fazda?]
        STATE3[Handoff payload]
    end

    SAVE1 -.-> STATE
    SAVE2 -.-> STATE
    SAVE3 -.-> STATE
    SAVE4 -.-> STATE
    SAVE5 -.-> STATE
    SAVE6 -.-> STATE
    SAVE7 -.-> STATE

    classDef start fill:#e3f2fd,stroke:#1976d2,stroke-width:3px
    classDef phase fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    classDef gate fill:#fce4ec,stroke:#c2185b
    classDef save fill:#e8f5e9,stroke:#388e3c
    classDef done fill:#c8e6c9,stroke:#2e7d32,stroke-width:3px
    classDef state fill:#f3e5f5,stroke:#7b1fa2

    class START,ASK,LOAD start
    class P1,P2,P3,P4,P5,P6,P7,P8 phase
    class P1A,P1B,P1C,P1D,P2A,P2B,P2C,P2D,P3A,P3B,P3C,P3D phase
    class P4A,P4B,P4C,P4D,P5A,P5B,P5C,P5D phase
    class P6A,P6B,P6C,P6D,P7A,P7B,P7C,P7D,P8A,P8B,P8C,P8D phase
    class GATE1,GATE2 gate
    class SAVE1,SAVE2,SAVE3,SAVE4,SAVE5,SAVE6,SAVE7 save
    class DONE done
    class STATE,STATE1,STATE2,STATE3 state
