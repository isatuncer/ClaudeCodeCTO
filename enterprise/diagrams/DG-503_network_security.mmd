%% DG-503: Network Guvenlik Diyagrami
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: Ag katmanlari, firewall kurallari, erisim kontrol
%% ---

graph TB
    INTERNET((Internet))

    subgraph "DMZ / Edge"
        style DMZ fill:#fef3c7
        CDN["CDN<br/>Statik asset"]
        WAF["WAF<br/>SQL injection<br/>XSS<br/>Rate limit"]
    end

    subgraph "Public Subnet"
        style Public fill:#dbeafe
        LB["Load Balancer<br/>Port 443 only<br/>SSL/TLS 1.3"]
    end

    subgraph "Private Subnet - App"
        style Private fill:#dcfce7
        APP["App Servers<br/>Port 3000<br/>Sadece LB'den erisim"]
    end

    subgraph "Private Subnet - Data"
        style Data fill:#fce7f3
        DB["PostgreSQL<br/>Port 5432<br/>Sadece App'ten erisim"]
        REDIS["Redis<br/>Port 6379<br/>Sadece App'ten erisim"]
    end

    subgraph "Management"
        style Management fill:#f3e8ff
        VPN["VPN Gateway<br/>Admin erisimi"]
        BASTION["Bastion Host<br/>SSH jump box"]
    end

    INTERNET -->|HTTPS 443| CDN
    INTERNET -->|HTTPS 443| WAF
    WAF -->|HTTP| LB
    LB -->|HTTP 3000| APP
    APP -->|TCP 5432| DB
    APP -->|TCP 6379| REDIS

    VPN -->|SSH 22| BASTION
    BASTION -->|SSH 22| APP
    BASTION -->|TCP 5432| DB

    INTERNET -.->|BLOCKED| DB
    INTERNET -.->|BLOCKED| REDIS
    INTERNET -.->|BLOCKED| APP
