%% DG-703: Release Akis Diyagrami
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: Code freeze'den production deploy'a kadar release sureci
%% ---

flowchart TD
    SPRINT_END((Sprint Sonu)) --> CODE_FREEZE["Code Freeze<br/>Yeni feature merge DURUR"]

    CODE_FREEZE --> RELEASE_BRANCH["Release Branch Olustur<br/>release/vX.Y.Z"]
    RELEASE_BRANCH --> VERSION["Version Bump<br/>package.json / pyproject.toml"]
    VERSION --> CHANGELOG_UPDATE["CHANGELOG Guncelle"]

    CHANGELOG_UPDATE --> QA_CYCLE["QA Cycle - Staging"]
    subgraph "QA Cycle"
        REGRESSION["Regression Test"]
        E2E["E2E Test"]
        SECURITY["Security Scan"]
        PERFORMANCE["Performance Test"]
        MANUAL_QA["Manuel QA"]
    end
    QA_CYCLE --> REGRESSION --> E2E --> SECURITY --> PERFORMANCE --> MANUAL_QA

    MANUAL_QA --> BUG_FOUND{Bug Bulundu?}
    BUG_FOUND -->|Evet P1/P2| HOTFIX["Release Branch'e Fix"]
    HOTFIX --> QA_CYCLE
    BUG_FOUND -->|Evet P3/P4| DEFER["Sonraki Release'e Ertele"]
    BUG_FOUND -->|Hayir| GO_NO_GO

    DEFER --> GO_NO_GO{"Go / No-Go Toplantisi<br/>(15 dk)"}

    GO_NO_GO -->|No-Go| FIX_ISSUES["Sorunlari Gider"]
    FIX_ISSUES --> QA_CYCLE
    GO_NO_GO -->|Go| MERGE_MAIN["Release -> Main Merge"]

    MERGE_MAIN --> TAG["Git Tag: vX.Y.Z"]
    TAG --> DEPLOY_PROD["Production Deploy<br/>Blue-Green"]
    DEPLOY_PROD --> SMOKE["Smoke Test<br/>(5 dk)"]

    SMOKE --> SMOKE_OK{Gecti?}
    SMOKE_OK -->|Hayir| ROLLBACK["OTOMATIK ROLLBACK"]
    ROLLBACK --> POSTMORTEM["Postmortem"]
    SMOKE_OK -->|Evet| MONITOR["Monitor 30dk<br/>Error rate < 1%"]

    MONITOR --> MONITOR_OK{Stabil?}
    MONITOR_OK -->|Hayir| ROLLBACK
    MONITOR_OK -->|Evet| ANNOUNCE["Release Duyurusu"]

    ANNOUNCE --> MERGE_DEVELOP["Release -> Develop Sync"]
    MERGE_DEVELOP --> CLEANUP["Branch Sil"]
    CLEANUP --> DONE((Release Tamamlandi))

    style GO_NO_GO fill:#f59e0b,color:#000
    style ROLLBACK fill:#dc2626,color:#fff
    style DONE fill:#16a34a,color:#fff
