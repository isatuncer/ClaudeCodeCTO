%% DG-202: Container Diyagrami (C4 Level 2)
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: Sistem icindeki ana container'lar (frontend, backend, DB, cache)
%% ---

graph TB
    subgraph "Frontend"
        WEB["Web App<br/>[React/Next.js]<br/>SPA veya SSR"]
        MOBILE["Mobile App<br/>[React Native/Flutter]<br/>iOS + Android"]
        ADMIN_UI["Admin Panel<br/>[React]<br/>Yonetim Arayuzu"]
    end

    subgraph "Backend"
        GATEWAY["API Gateway<br/>[Nginx/Traefik]<br/>Reverse Proxy + Rate Limit"]
        API["API Server<br/>[Node.js/Python/Go]<br/>REST API + Business Logic"]
        WORKER["Background Worker<br/>[Bull/Celery]<br/>Async Jobs"]
        SCHEDULER["Scheduler<br/>[Cron/Agenda]<br/>Zamanlanmis Gorevler"]
    end

    subgraph "Data"
        DB[("PostgreSQL<br/>Ana Veritabani")]
        REDIS[("Redis<br/>Cache + Session + Queue")]
        S3["Object Storage<br/>[S3/GCS]<br/>Dosya Depolama"]
    end

    subgraph "Observability"
        LOG["Log Aggregator<br/>[ELK/Loki]"]
        MONITOR["Monitoring<br/>[Prometheus+Grafana]"]
        SENTRY["Error Tracking<br/>[Sentry]"]
    end

    WEB -->|HTTPS| GATEWAY
    MOBILE -->|HTTPS| GATEWAY
    ADMIN_UI -->|HTTPS| GATEWAY

    GATEWAY -->|HTTP| API
    API --> DB
    API --> REDIS
    API --> S3
    API -->|Queue| REDIS
    REDIS -->|Job| WORKER
    WORKER --> DB
    WORKER --> S3

    API --> LOG
    API --> MONITOR
    API --> SENTRY
