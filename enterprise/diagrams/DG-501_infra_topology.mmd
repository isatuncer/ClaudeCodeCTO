%% DG-501: Altyapi Topolojisi
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: Cloud/on-prem altyapi yapisi - network, subnet, servisler
%% ---

graph TB
    subgraph "Internet"
        USERS((Kullanicilar))
        DNS["DNS<br/>CloudFlare/Route53"]
    end

    subgraph "Edge Layer"
        CDN["CDN<br/>CloudFront/CloudFlare"]
        WAF["WAF + DDoS<br/>CloudFlare/AWS Shield"]
    end

    subgraph "Public Subnet"
        LB["Load Balancer<br/>ALB/Nginx<br/>SSL Termination"]
    end

    subgraph "Private Subnet - Compute"
        direction LR
        APP1["App Container 1<br/>CPU: 2 | RAM: 4GB"]
        APP2["App Container 2<br/>CPU: 2 | RAM: 4GB"]
        WORKER["Worker Container<br/>CPU: 1 | RAM: 2GB"]
        CRON["Scheduler<br/>CPU: 0.5 | RAM: 1GB"]
    end

    subgraph "Private Subnet - Data"
        DB_PRIMARY[("PostgreSQL Primary<br/>CPU: 4 | RAM: 16GB<br/>SSD: 100GB")]
        DB_REPLICA[("PostgreSQL Replica<br/>CPU: 2 | RAM: 8GB")]
        REDIS[("Redis Cluster<br/>RAM: 4GB")]
    end

    subgraph "Storage"
        S3["Object Storage<br/>S3/GCS<br/>Unlimited"]
        BACKUP["Backup Storage<br/>30 gun retention"]
    end

    subgraph "Monitoring"
        PROMETHEUS["Prometheus<br/>Metrik toplama"]
        GRAFANA["Grafana<br/>Dashboard"]
        LOKI["Loki<br/>Log toplama"]
        SENTRY["Sentry<br/>Error tracking"]
        UPTIME["Uptime Monitor<br/>Health check"]
    end

    USERS --> DNS --> CDN --> WAF --> LB
    LB --> APP1 & APP2
    APP1 & APP2 --> DB_PRIMARY
    APP1 & APP2 --> DB_REPLICA
    APP1 & APP2 --> REDIS
    APP1 & APP2 --> S3
    REDIS --> WORKER
    WORKER --> DB_PRIMARY
    DB_PRIMARY --> DB_REPLICA
    DB_PRIMARY --> BACKUP
    APP1 --> PROMETHEUS & LOKI & SENTRY
    PROMETHEUS --> GRAFANA
    UPTIME --> LB
