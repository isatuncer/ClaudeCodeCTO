%% DG-504: Monitoring Mimarisi
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: Metrik toplama, loglama, alerting, dashboard yapisi
%% ---

graph TB
    subgraph "Veri Kaynaklari"
        APP["App Server<br/>Metrik + Log"]
        DB["PostgreSQL<br/>Query stats"]
        REDIS["Redis<br/>Memory stats"]
        LB["Load Balancer<br/>Request stats"]
        CONTAINER["Container<br/>CPU/RAM/Disk"]
    end

    subgraph "Toplama"
        PROM["Prometheus<br/>Metrik scraping<br/>15s interval"]
        LOKI["Loki / ELK<br/>Log aggregation"]
        SENTRY["Sentry<br/>Error tracking"]
    end

    subgraph "Gorselletirme"
        GRAFANA["Grafana<br/>Dashboard"]
        GRAFANA_DASH1["Overview Dashboard"]
        GRAFANA_DASH2["API Performance"]
        GRAFANA_DASH3["Database Health"]
        GRAFANA_DASH4["Security Events"]
    end

    subgraph "Alerting"
        ALERT_MGR["Alertmanager<br/>Kural degerlendirme"]
        SLACK["Slack<br/>Warning"]
        PHONE["Telefon/SMS<br/>Critical"]
        EMAIL_ALERT["Email<br/>Info"]
    end

    subgraph "Uptime"
        UPTIME["Uptime Monitor<br/>Dis kontrol<br/>1dk interval"]
    end

    APP --> PROM
    APP --> LOKI
    APP --> SENTRY
    DB --> PROM
    REDIS --> PROM
    LB --> PROM
    CONTAINER --> PROM

    PROM --> GRAFANA
    LOKI --> GRAFANA
    GRAFANA --> GRAFANA_DASH1 & GRAFANA_DASH2 & GRAFANA_DASH3 & GRAFANA_DASH4

    PROM --> ALERT_MGR
    ALERT_MGR -->|Warning| SLACK
    ALERT_MGR -->|Critical| PHONE
    ALERT_MGR -->|Info| EMAIL_ALERT

    UPTIME -->|Down Alert| PHONE
    UPTIME -->|Slow Alert| SLACK
