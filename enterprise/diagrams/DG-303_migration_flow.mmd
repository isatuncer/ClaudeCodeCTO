%% DG-303: Migration Akis Diyagrami
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: DB migration'in deploy suresindeki akisi
%% ---

flowchart TD
    START((Migration Baslat)) --> BACKUP[1. DB Backup Al]
    BACKUP --> CHECK_STAGING{2. Staging'de Test Edildi mi?}

    CHECK_STAGING -->|Hayir| STAGING[Staging'de Test Et]
    STAGING --> CHECK_STAGING
    CHECK_STAGING -->|Evet| DRY_RUN[3. Dry Run - Production]

    DRY_RUN --> SAFE{4. Zero-Downtime Uyumlu?}

    SAFE -->|Evet - Additive| ONLINE[Online Migration<br/>ADD COLUMN, CREATE TABLE]
    SAFE -->|Hayir - Destructive| MAINTENANCE[Bakim Penceresi Ac<br/>ALTER TYPE, DROP COLUMN]

    ONLINE --> RUN_UP[5. Migration UP Calistir]
    MAINTENANCE --> NOTIFY[Kullanicilari Bilgilendir]
    NOTIFY --> RUN_UP

    RUN_UP --> VERIFY{6. Dogrulama}
    VERIFY -->|Basarili| APP_DEPLOY[7. Uygulama Deploy]
    VERIFY -->|Basarisiz| ROLLBACK[ROLLBACK: Migration DOWN]

    APP_DEPLOY --> HEALTH{8. Health Check}
    HEALTH -->|OK| DONE((Tamamlandi))
    HEALTH -->|FAIL| APP_ROLLBACK[App Rollback]
    APP_ROLLBACK --> ROLLBACK
    ROLLBACK --> RESTORE{Backup Restore Gerekli?}
    RESTORE -->|Evet| BACKUP_RESTORE[Backup'tan Geri Yukle]
    RESTORE -->|Hayir| INVESTIGATE[Sorun Arastir]
    BACKUP_RESTORE --> INVESTIGATE
