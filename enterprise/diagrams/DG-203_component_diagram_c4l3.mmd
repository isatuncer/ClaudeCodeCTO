graph TB
    subgraph "API Server"
        subgraph "Middleware Pipeline"
            CORS[CORS]
            RATE[Rate Limiter]
            AUTH_MW[Auth Middleware]
            VALIDATE[Input Validator]
            LOG_MW[Request Logger]
        end

        subgraph "Moduller"
            AUTH_MOD["Auth Module<br/>Login, Register, OAuth, MFA"]
            USER_MOD["User Module<br/>Profil, Ayarlar, RBAC"]
            PRODUCT_MOD["[Core Module 1]<br/>CRUD + Is Mantigi"]
            ORDER_MOD["[Core Module 2]<br/>CRUD + Is Mantigi"]
            PAYMENT_MOD["Payment Module<br/>Odeme, Iade"]
            NOTIFY_MOD["Notification Module<br/>Email, Push, SMS"]
            FILE_MOD["File Module<br/>Upload, Resize, CDN"]
            SEARCH_MOD["Search Module<br/>Full-text, Filter"]
        end

        subgraph "Ortak"
            ERROR_HANDLER[Error Handler]
            EVENT_BUS[Event Bus]
            CACHE_LAYER[Cache Layer]
        end
    end

    CORS --> RATE --> AUTH_MW --> VALIDATE --> LOG_MW

    AUTH_MOD --> EVENT_BUS
    USER_MOD --> CACHE_LAYER
    ORDER_MOD --> EVENT_BUS
    PAYMENT_MOD --> EVENT_BUS
    EVENT_BUS --> NOTIFY_MOD
    SEARCH_MOD --> CACHE_LAYER
