graph TD
    subgraph "Entry Points"
        MAIN["main.ts<br/>App Bootstrap"]
    end

    subgraph "Core Modules"
        AUTH["Auth Module<br/>Login, Register, JWT"]
        USER["User Module<br/>Profile, Settings"]
        CORE1["[Core Module 1]<br/>Ana is mantigi"]
        CORE2["[Core Module 2]<br/>Ana is mantigi"]
    end

    subgraph "Support Modules"
        PAYMENT["Payment Module"]
        NOTIFICATION["Notification Module"]
        FILE["File Module"]
        SEARCH["Search Module"]
    end

    subgraph "Shared/Common"
        MIDDLEWARE["Middleware<br/>Auth, Logger, Validator"]
        DATABASE["Database<br/>Connection, Migrations"]
        CACHE["Cache Layer<br/>Redis Client"]
        EVENT["Event Bus<br/>Pub/Sub"]
        ERROR["Error Handler<br/>Centralized"]
        CONFIG["Config<br/>Env Variables"]
    end

    MAIN --> AUTH & USER & CORE1 & CORE2
    MAIN --> PAYMENT & NOTIFICATION & FILE & SEARCH
    MAIN --> MIDDLEWARE & DATABASE & CONFIG

    AUTH --> DATABASE & CACHE & EVENT
    USER --> DATABASE & CACHE
    CORE1 --> DATABASE & CACHE & EVENT
    CORE2 --> DATABASE & CACHE & EVENT & SEARCH
    PAYMENT --> DATABASE & EVENT
    NOTIFICATION --> EVENT & CACHE
    FILE --> CACHE
    SEARCH --> DATABASE & CACHE

    EVENT --> NOTIFICATION
    EVENT --> PAYMENT

    AUTH -.->|"Kullanir"| MIDDLEWARE
    CORE1 -.->|"Kullanir"| MIDDLEWARE
    CORE2 -.->|"Kullanir"| MIDDLEWARE
