%% DG-502: CI/CD Pipeline Diyagrami
%% Durum: DRAFT
%% Editor: https://mermaid.live
%% Aciklama: Commit'ten production'a kadar otomasyon akisi
%% ---

flowchart LR
    subgraph "Developer"
        COMMIT[Git Commit]
        PR[Pull Request]
    end

    subgraph "CI Pipeline"
        LINT["1. Lint + Format<br/>ESLint/Ruff"]
        SECRET["2. Secret Scan<br/>gitleaks"]
        UNIT["3. Unit Test<br/>Jest/Pytest"]
        BUILD["4. Build<br/>TypeScript/Docker"]
        INTEGRATION["5. Integration Test<br/>TestContainers"]
        SCA["6. Dependency Scan<br/>Snyk/npm audit"]
        SAST["7. SAST<br/>Semgrep/CodeQL"]
        COVERAGE["8. Coverage Check<br/>>= 80%"]
    end

    subgraph "CD Pipeline - Staging"
        DOCKER_BUILD["9. Docker Build<br/>Multi-stage"]
        CONTAINER_SCAN["10. Container Scan<br/>Trivy"]
        DEPLOY_STG["11. Deploy Staging"]
        E2E["12. E2E Test<br/>Playwright"]
        VISUAL["13. Visual Regression"]
        LIGHTHOUSE["14. Lighthouse CI"]
    end

    subgraph "CD Pipeline - Production"
        APPROVE{"15. Go/No-Go"}
        DEPLOY_PROD["16. Deploy Production<br/>Blue-Green"]
        SMOKE["17. Smoke Test"]
        MONITOR["18. Monitor (30dk)"]
    end

    subgraph "Rollback"
        ROLLBACK["Auto Rollback<br/>error > 5%"]
    end

    COMMIT --> PR --> LINT --> SECRET --> UNIT --> BUILD
    BUILD --> INTEGRATION --> SCA --> SAST --> COVERAGE
    COVERAGE --> DOCKER_BUILD --> CONTAINER_SCAN
    CONTAINER_SCAN --> DEPLOY_STG --> E2E --> VISUAL --> LIGHTHOUSE
    LIGHTHOUSE --> APPROVE
    APPROVE -->|Go| DEPLOY_PROD --> SMOKE --> MONITOR
    APPROVE -->|No-Go| PR
    MONITOR -->|Error| ROLLBACK
    SMOKE -->|Fail| ROLLBACK

    style APPROVE fill:#f59e0b,color:#000
    style ROLLBACK fill:#dc2626,color:#fff
