# ============================================================
# ClaudeCodeCTO .gitignore
# ============================================================

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Temp
*.tmp
*.log
*.bak

# Project documents — user-generated per project, not part of the repo
project-docs/*
!project-docs/README.md

# Don't ignore submodules (structure is defined in .gitmodules)
!sources/

# Node (if any tooling is added)
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Build artifacts
*.exe
*.dll
*.so
*.dylib

# ============================================================
# ClaudeCodeCTO pipeline artifacts
# These are regenerable via `bash scripts/setup.sh`
# ============================================================

# Large generated catalogs (Stage 2-3)
decisions/catalog.json
decisions/scored-catalog.json

# Self-scoring batches and results (Stage 3b)
decisions/self-scoring/

# Pipeline run log
decisions/setup.log

# Legacy scanner TSV outputs
decisions/*-map.tsv

# Conflict reports (dated)
decisions/conflicts-*.md

# Install stage leftovers (should always be under /c/tmp/ anyway)
claude-install-stage-*
claude-install-backup-*

# Local-only documentation (kept on disk but not pushed)
# Keep docs/i18n/ (translated READMEs) and docs/manuals/ (catalog snapshots)
docs/*
!docs/i18n/
!docs/manuals/
docs/i18n/.*
docs/manuals/.*

# Local-only obsolete/legacy scripts (kept on disk but not pushed)
scripts/scanner.sh
scripts/inventory.sh
scripts/SETUP_README.md

# Local-only analysis pipeline scripts (used to pre-build decisions/)
# End users don't run these — decisions/selected.json is pre-built
# and checked into the repo.
scripts/extractor.py
scripts/scorer_rubric.py
scripts/curator.py
scripts/orchestrator.py
scripts/budget.py
scripts/validate_agents.py
scripts/merge_self_scoring.py
scripts/prepare_self_scoring.py
